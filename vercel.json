{
  "version": 2,
  "builds": [
    {
      "src": "backend/finance_api/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/finance_api/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "backend/finance_api/wsgi.py"
    },
    {
      "src": "/o/(.*)",
      "dest": "backend/finance_api/wsgi.py"
    }
  ]
}
